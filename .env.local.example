# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Project Settings > API > JWT Settings > JWT Secret (legacy HS256 secret)
SUPABASE_JWT_SECRET=your-jwt-secret

# Random long random string used to sign the app session cookie (separate from JWT secret)
SESSION_COOKIE_SECRET=generate-a-long-random-string

# Coach bootstrap (used once by the seed script to create Jon's coach account)
COACH_USERNAME=jon
COACH_PIN=194756
